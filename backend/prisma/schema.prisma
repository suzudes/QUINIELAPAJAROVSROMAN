generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  name         String       // "PAJARO" o "ROMAN"
  accessToken  String       @unique
  predictions  Prediction[]
}

model Match {
  id          Int          @id
  kickoffUtc  DateTime
  status      String       // SCHEDULED, TIMED, IN_PLAY, FINISHED
  homeTeam    String?      // AHORA OPCIONAL
  awayTeam    String?      // AHORA OPCIONAL
  homeScore   Int?
  awayScore   Int?
  stage       String
  predictions Prediction[]
}

model Prediction {
  id        String   @id @default(uuid())
  userId    String
  matchId   Int
  predHome  Int
  predAway  Int
  state     String   @default("LOCKED") // LOCKED, CANCELLED, SCORED
  points    Int      @default(0)
  user      User     @relation(fields: [userId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}
